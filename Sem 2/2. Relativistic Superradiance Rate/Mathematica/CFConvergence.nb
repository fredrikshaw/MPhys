         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Re", "[", "sol", "]"}], "<", "0"}], "||", 
           RowBox[{
            RowBox[{"Im", "[", "sol", "]"}], "<=", "0"}]}], ",", 
          RowBox[{"Return", "[", "Missing", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"sol", ",", 
          RowBox[{"2", "*", 
           RowBox[{"Im", "[", "sol", "]"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", 
     RowBox[{"RUN", " ", "CONVERGENCE", " ", "STUDY"}], "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "==="}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Nmax list: \>\"", ",", "nMaxList"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Alpha values: \>\"", ",", "alphaList"}], "]"}], ";"}], "\n",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"convergenceData", "=", 
     RowBox[{"Association", "[", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Alpha]val", "=", "\[Alpha]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<\\n=== Processing \[Alpha] = \>\"", ",", 
         RowBox[{"N", "[", 
          RowBox[{"\[Alpha]val", ",", "4"}], "]"}], ",", "\"\< ===\>\""}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"hydroSeed", "=", 
        RowBox[{"HydrogenGamma", "[", 
         RowBox[{
         "nQN", ",", "lQN", ",", "mQN", ",", "\[Alpha]val", ",", "atBH"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"initSeedRe", "=", 
        RowBox[{"\[Alpha]val", "*", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"\[Alpha]val", "^", "2"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", "*", 
              RowBox[{"nQN", "^", "2"}]}], ")"}]}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"initSeedIm", "=", "hydroSeed"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  Hydrogenic seed: Re=\>\"", ",", 
         RowBox[{"N", "[", 
          RowBox[{"initSeedRe", ",", "4"}], "]"}], ",", "\"\<  Im=\>\"", ",", 
         RowBox[{"N", "[", 
          RowBox[{"initSeedIm", ",", "4"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"refResult", "=", 
        RowBox[{"FindSRRateAtNmax", "[", 
         RowBox[{
         "\[Alpha]val", ",", "10000", ",", "initSeedRe", ",", "initSeedIm"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"refResult", "===", "Missing"}], ",", 
         RowBox[{
          RowBox[{
          "Print", 
           "[", "\"\<  Reference at Nmax=10000 failed! Skipping alpha.\>\"", 
           "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"Continue", "[", "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"refOmega", "=", 
        RowBox[{"refResult", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"refRate", "=", 
        RowBox[{"refResult", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<  Reference rate (Nmax=10000): \>\"", ",", 
         RowBox[{"ScientificForm", "[", 
          RowBox[{
           RowBox[{"N", "[", 
            RowBox[{"refRate", ",", "6"}], "]"}], ",", "4"}], "]"}]}], "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"dataForAlpha", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"curSeedRe", "=", 
        RowBox[{"Re", "[", "refOmega", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"curSeedIm", "=", 
        RowBox[{"Im", "[", "refOmega", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<  Trying Nmax=\>\"", ",", "Nm"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"res", "=", 
           RowBox[{"FindSRRateAtNmax", "[", 
            RowBox[{
            "\[Alpha]val", ",", "Nm", ",", "curSeedRe", ",", "curSeedIm"}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
