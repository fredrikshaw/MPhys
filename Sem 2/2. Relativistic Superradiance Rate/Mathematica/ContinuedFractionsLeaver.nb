          RowBox[{"\[Alpha]Max", ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "2"}], "}"}]}], "]"}], "]"}], 
        "<>", "\"\<.dat\>\""}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
