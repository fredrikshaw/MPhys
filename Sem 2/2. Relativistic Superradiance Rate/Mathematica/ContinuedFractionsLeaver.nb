                 RowBox[{"upPrevPrevPrevAlpha", "=", "upPrevPrevAlpha"}], ";",
                  "\[IndentingNewLine]", 
                 RowBox[{"upPrevPrevRe", "=", "upPrevRe"}], ";", 
                 RowBox[{"upPrevPrevIm", "=", "upPrevIm"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"upPrevPrevAlpha", "=", "upPrevAlpha"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"upPrevRe", "=", 
                  RowBox[{"Re", "[", "sol", "]"}]}], ";", 
                 RowBox[{"upPrevIm", "=", 
                  RowBox[{"Im", "[", "sol", "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"upPrevAlpha", "=", "\[Alpha]"}]}], ",", 
                RowBox[{"(*", 
                 RowBox[{"down", " ", "direction"}], "*)"}], 
                RowBox[{
                 RowBox[{"downPrevRe3", "=", "downPrevRe2"}], ";", 
                 RowBox[{"downPrevIm3", "=", "downPrevIm2"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"downPrevAlpha3", "=", "downPrevAlpha2"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"downPrevRe2", "=", "downPrevRe"}], ";", 
                 RowBox[{"downPrevIm2", "=", "downPrevIm"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"downPrevAlpha2", "=", "downPrevAlpha"}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"downPrevRe", "=", 
                  RowBox[{"Re", "[", "sol", "]"}]}], ";", 
                 RowBox[{"downPrevIm", "=", 
                  RowBox[{"Im", "[", "sol", "]"}]}], ";", 
                 "\[IndentingNewLine]", 
                 RowBox[{"downPrevAlpha", "=", "\[Alpha]"}]}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"cfData", ",", 
                RowBox[{"{", 
                 RowBox[{"\[Alpha]", ",", 
                  RowBox[{"Im", "[", "sol", "]"}]}], "}"}]}], "]"}]}], ",", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"Failure", ":", 
                RowBox[{"increment", " ", "counter"}]}], ",", 
               RowBox[{
               "stop", " ", "direction", " ", "after", " ", "3", " ", 
                "consecutive"}]}], "*)"}], 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"dir", "==", "1"}], ",", 
               RowBox[{
                RowBox[{"upConsecFail", "++"}], ";", "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"upConsecFail", ">=", "3"}], ",", 
                  RowBox[{
                   RowBox[{"upDone", "=", "True"}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Print", "[", 
                    RowBox[{"\"\<  Up-sweep stopped at \[Alpha] = \>\"", ",", 
                    RowBox[{"NumberForm", "[", 
                    RowBox[{
                    RowBox[{"N", "[", 
                    RowBox[{"\[Alpha]", ",", "4"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"4", ",", "3"}], "}"}]}], "]"}]}], "]"}]}]}], 
                 "]"}]}], ",", 
               RowBox[{
                RowBox[{"downConsecFail", "++"}], ";", "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"downConsecFail", ">=", "3"}], ",", 
                  RowBox[{
                   RowBox[{"downDone", "=", "True"}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"Print", "[", 
                    RowBox[{"\"\<  Down-sweep stopped at \[Alpha] = \>\"", ",", 
                    RowBox[{"NumberForm", "[", 
                    RowBox[{
                    RowBox[{"N", "[", 
                    RowBox[{"\[Alpha]", ",", "4"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"4", ",", "3"}], "}"}]}], "]"}]}], "]"}]}]}], 
                 "]"}]}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{
            "Advance", " ", "index", " ", "for", " ", "this", " ", 
             "direction"}], "*)"}], 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"dir", "==", "1"}], ",", 
             RowBox[{"upIdx", "++"}], ",", 
             RowBox[{"downIdx", "--"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"dir", ",", 
            RowBox[{"{", 
             RowBox[{"1", ",", 
              RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], "  ", 
         RowBox[{"(*", 
          RowBox[{
          "Process", " ", "up", " ", "then", " ", "down", " ", "each", " ", 
           "iteration"}], "*)"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Final", " ", "output"}], "*)"}], 
      RowBox[{"progressBar", "=", "1."}], ";", "\[IndentingNewLine]", 
      RowBox[{"tElapsed", "=", 
       RowBox[{
        RowBox[{"AbsoluteTime", "[", "]"}], "-", "tStart"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"progressLabel", "=", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"StringForm", "[", 
          
          RowBox[{"\"\<  Complete: `` / `` points found  |  Total time: \
``\>\"", ",", 
           RowBox[{"Length", "[", "cfData", "]"}], ",", "nPoints", ",", 
           RowBox[{"formatTime", "[", "tElapsed", "]"}]}], "]"}], "}"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"cfData", "===", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{
         RowBox[{"Print", "[", "\"\<No valid points.\>\"", "]"}], ";", 
         RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"hydroData", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Alpha]", ",", 
           RowBox[{"HydrogenGamma", "[", 
            RowBox[{"n", ",", "l", ",", "m", ",", "\[Alpha]", ",", "at"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Alpha]", ",", "\[Alpha]List"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"exportData", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"cfRow", ",", "cfVal"}], "}"}], ",", 
           RowBox[{
            RowBox[{"cfRow", "=", 
             RowBox[{"Select", "[", 
              RowBox[{"cfData", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "==", 
                 RowBox[{"\[Alpha]List", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], "&"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"cfVal", "=", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"cfRow", "=!=", 
                RowBox[{"{", "}"}]}], ",", 
               RowBox[{"2", "*", 
                RowBox[{"cfRow", "[", 
                 RowBox[{"[", 
                  RowBox[{"1", ",", "2"}], "]"}], "]"}]}], 
               ",", "\"\<Failed\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{"\[Alpha]List", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], ",", "16"}], "]"}], ",", 
              "cfVal", ",", 
              RowBox[{"N", "[", 
               RowBox[{
                RowBox[{"hydroData", "[", 
                 RowBox[{"[", 
                  RowBox[{"j", ",", "2"}], "]"}], "]"}], ",", "16"}], "]"}]}],
              "}"}]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", 
           RowBox[{"Length", "[", "\[Alpha]List", "]"}]}], "}"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"filename", "=", 
       RowBox[{"\"\<SR_n\>\"", "<>", 
        RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<l\>\"", "<>", 
        RowBox[{"ToString", "[", "l", "]"}], "<>", "\"\<m\>\"", "<>", 
        RowBox[{"ToString", "[", "m", "]"}], "<>", "\"\<_at\>\"", "<>", 
        RowBox[{"ToString", "[", 
