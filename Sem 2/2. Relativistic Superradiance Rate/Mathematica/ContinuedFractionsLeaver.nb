               RowBox[{"#", "[", 
                RowBox[{"[", "3", "]"}], "]"}]}], "}"}], "&"}], ",", 
            "exportData"}], "]"}], ",", 
          RowBox[{"{", 
           
           RowBox[{"\"\<alpha\>\"", ",", "\"\<CF_Gamma\>\"", 
            ",", "\"\<Hydro_Gamma\>\""}], "}"}]}], "]"}], 
        ",", "\"\<TSV\>\""}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<\\nData exported to: \>\"", ",", "filename"}], "]"}], ";",
       "\[IndentingNewLine]", 
