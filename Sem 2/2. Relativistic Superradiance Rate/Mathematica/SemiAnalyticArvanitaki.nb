Cell[CellGroupData[{
Cell["\<\
(* ============================================================
   Semi-Analytic Superradiance Rate Calculation
   Arvanitaki & Dubovsky, arXiv:1004.3558
   FIXED VERSION - all bugs corrected

   Root causes of previous failures:
   1. rPlus/rMinus defined OUTSIDE any Module, so Mathematica
      evaluated them immediately at definition time when aSpin
      happened to be 0.999 => tried to Set the *number* 1.4358...
      Fix: wrap in Module or use explicit numeric arguments only.
   2. dRfarFunc / dRnearFunc used Evaluate[D[...]] with symbolic
      aSpin still present => huge unevaluated symbolic output.
      Fix: do ALL differentiation numerically via finite differences,
      entirely inside Module with concrete numbers.

   Units: rg = 1  (geometrized)
   ============================================================ *)

(* ---- Horizon geometry (plain functions, no delayed rules) ---- *)
rp[a_]  := 1 + Sqrt[1 - a^2]
rm[a_]  := 1 - Sqrt[1 - a^2]
omP[a_] := a / (2 * rp[a])

(* ---- Hydrogen spectrum real part of omega (Eq. 7) ---- *)
omegaR0[alpha_, l_, n_] :=
  With[{nBar = n + l + 1},
    alpha * (1 - alpha^2/(2*nBar^2))
  ]

(* ---- Far-zone solution Rfar (Eq. 15) ----
   Rfar(r) = (2k r)^l * exp(-kr) * U(l+1-alpha^2/(2k), 2(l+1), 2kr)
   k = sqrt(mu^2 - omega^2),  mu = alpha  (rg=1)
   All arguments are passed as numbers; no symbolic patterns remain. *)
Rfar[r_?NumericQ, alpha_?NumericQ, omega_, l_Integer] :=
  Module[{k, a1, z},
    k  = Sqrt[N[alpha^2 - omega^2]];
    a1 = l + 1 - alpha^2/(2*k);
    z  = 2*k*r;
    (z)^l * Exp[-k*r] * HypergeometricU[a1, 2*(l+1), z]
  ]

(* Numerical derivative of Rfar via finite difference *)
dRfar[r_?NumericQ, alpha_?NumericQ, omega_, l_Integer] :=
  Module[{h = r * 1.*^-6},
    (Rfar[r+h, alpha, omega, l] - Rfar[r-h, alpha, omega, l]) / (2*h)
  ]

(* ---- Near-horizon solution Rnear (Eq. 17) ----
   Rnear = ((r-r+)/(r-r-))^(-iP) * 2F1(-l, l+1, 1+2iP, (r-r-)/(r+-r-))
   P = 2 r+ (omega - m omega+) / (r+ - r-)
   Satisfies purely-ingoing boundary condition at horizon. *)
Rnear[r_?NumericQ, alpha_?NumericQ, omega_, l_Integer, m_Integer,
      aSpin_?NumericQ] :=
  Module[{rpp, rmm, P, z},
    rpp = rp[aSpin];
    rmm = rm[aSpin];
    P   = 2*rpp*(omega - m*omP[aSpin]) / (rpp - rmm);
    z   = (r - rmm) / (rpp - rmm);
    ((r - rpp)/(r - rmm))^(-I*P) *
      Hypergeometric2F1[-l, l+1, 1 + 2*I*P, z]
  ]

(* Numerical derivative of Rnear via finite difference *)
dRnear[r_?NumericQ, alpha_?NumericQ, omega_, l_Integer, m_Integer,
       aSpin_?NumericQ] :=
  Module[{h = r * 1.*^-6},
    (Rnear[r+h, alpha, omega, l, m, aSpin] -
     Rnear[r-h, alpha, omega, l, m, aSpin]) / (2*h)
  ]

(* ---- Wronskian W = Rfar * dRnear - Rnear * dRfar ---- *)
MyWronskian[rStar_?NumericQ, alpha_?NumericQ, omR_?NumericQ,
          omI_?NumericQ, l_Integer, m_Integer, aSpin_?NumericQ] :=
  Module[{omega, Rf, dRf, Rn, dRn},
    omega = omR + I*omI;
    Rf  = N[Rfar[rStar, alpha, omega, l], 30];
    dRf = N[dRfar[rStar, alpha, omega, l], 30];
    Rn  = N[Rnear[rStar, alpha, omega, l, m, aSpin], 30];
    dRn = N[dRnear[rStar, alpha, omega, l, m, aSpin], 30];
    Rf * dRn - Rn * dRf
  ]

(* ---- Optimal matching point r* ----
   Geometric mean of near-zone upper edge and far-zone lower edge.
   Near zone: r+ < r << (l/alpha)^2
   Far zone:  r >> rg = 1                                        *)
rStar0[alpha_?NumericQ, l_Integer, aSpin_?NumericQ] :=
  Module[{rLow, rHigh},
    rLow  = rp[aSpin] + 0.5;
    rHigh = Min[(l/alpha)^2 * 0.5, 50.0];
    rHigh = Max[rHigh, rLow + 0.5];
    Sqrt[rLow * rHigh]
  ]

(* ============================================================
   SECTION A: ANALYTIC FORMULA Gamma (Eq. 18)
   Gamma_lmn = 2 mu alpha^{4l+4} r+ (m omega+ - mu) C_lmn
   ============================================================ *)
GammaAnalytic[alpha_?NumericQ, l_Integer, m_Integer, n_Integer,
              aSpin_?NumericQ] :=
  Module[{mu, rpp, omegaP, jProd, Clmn},
    mu     = alpha;
    rpp    = N[rp[aSpin]];
    omegaP = N[omP[aSpin]];

    jProd = Product[
      j^2*(1 - aSpin^2) + 4*rpp^2*(m*omegaP - mu)^2,
      {j, 1, l}
    ];

    Clmn = N[
      (2^(4l+2) * Factorial[2l+n+1]) /
      ((l+n+1)^(2l+4) * Factorial[n] *
       Factorial[l]^2 * Factorial[2l]^2 * Factorial[2l+1]^2)
    ] * jProd;

    2 * mu * alpha^(4l+4) * rpp * (m*omegaP - mu) * Clmn
  ]

(* ============================================================
   SECTION B: SEMI-ANALYTIC RATE via Wronskian matching
   Algorithm:
   1. omega_R from hydrogen spectrum
   2. Find r* in the overlap region
   3. W0 = W(r*; omega_R, 0)  -- Wronskian at real omega
   4. Linearize: delta_omI = -Im[W0] / (d Im[W] / d omI)|_{omI=0}
   5. Gamma = 2 * delta_omI
   ============================================================ *)
GammaSemiAnalytic[alpha_?NumericQ, l_Integer, m_Integer, n_Integer,
                  aSpin_?NumericQ, OptionsPattern[{Verbose -> False}]] :=
  Module[{mu, omR, rStar, W0, Wpert, eps, dWdomI, omI, Gamma,
          verbose},
    verbose = OptionValue[Verbose];
    mu      = N[alpha];
    omR     = N[omegaR0[alpha, l, n]];

    (* Superradiance condition check *)
    If[omR >= m * N[omP[aSpin]],
      If[verbose, Print[\"NOT superradiant: omega >= m*omega+\"]];
      Return[0.`]
    ];

    rStar = N[rStar0[alpha, l, aSpin]];
    If[verbose, Print[\"r* = \", rStar, \"   (r+ = \", N[rp[aSpin]], \")\"]];

    (* Wronskian at purely real omega *)
    W0 = MyWronskian[rStar, alpha, omR, 0., l, m, aSpin];
    If[verbose, Print[\"W(omI=0) = \", W0]];

    (* Numerical derivative dW/d(omI) via finite difference *)
    eps   = 1.*^-7;
    Wpert = MyWronskian[rStar, alpha, omR, eps, l, m, aSpin];
    dWdomI = Im[(Wpert - W0) / eps];
    If[verbose, Print[\"dW/d(omI) = \", dWdomI]];

    If[Abs[dWdomI] < 1.*^-40,
      If[verbose, Print[\"Derivative vanishes; analytic fallback\"]];
      Return[Abs[N[GammaAnalytic[alpha, l, m, n, aSpin]]]]
    ];

    (* Newton step *)
    omI   = -Im[W0] / dWdomI;
    Gamma = 2 * omI;

    If[Gamma <= 0.,
      If[verbose, Print[\"Negative Gamma; analytic fallback\"]];
      Gamma = Abs[N[GammaAnalytic[alpha, l, m, n, aSpin]]]
    ];

    If[verbose, Print[\"Gamma (semi-analytic) = \", Gamma]];
    Gamma
  ]

(* ============================================================
   SECTION C: SCAN OVER alpha FOR A GIVEN LEVEL
   Returns {analytic data, semi-analytic data} for plotting.
   ============================================================ *)
ScanAlpha[lv_Integer, mv_Integer, nv_Integer, aSpin_?NumericQ,
          nPts_Integer: 50] :=
  Module[{alphaMax, alphas, gA, gSA},
    (* Find upper alpha: omega_R = m*omega+ *)
    alphaMax = Quiet[
      FindRoot[
        omegaR0[x, lv, nv] - mv*omP[aSpin] == 0,
        {x, mv*omP[aSpin]*1.01}
      ][[1, 2]]
    ];
    alphaMax = 0.97 * alphaMax;
    alphas   = Table[0.05 + i*(alphaMax - 0.05)/nPts, {i, 0, nPts}];
    alphas   = Select[alphas, # > 0 &];

    gA = Map[
      Function[a, {a, Abs[N[GammaAnalytic[a, lv, mv, nv, aSpin]]]}],
      alphas
    ];
    gSA = Map[
      Function[a, {a, Abs[GammaSemiAnalytic[a, lv, mv, nv, aSpin]]}],
      alphas
    ];

    {Select[gA, #[[2]] > 0 &], Select[gSA, #[[2]] > 0 &]}
  ]

(* ============================================================
   SECTION D: REPRODUCE FIGURE 5  (a/rg = 0.999, l=m=1..5)
   Solid lines: semi-analytic.  Dashed lines: analytic Eq. 18.
   ============================================================ *)
PlotFig5[] :=
  Module[{aSpin = 0.999, lMax = 5,
          cols = {Blue, Red, Darker[Green], Purple, Orange},
          plots = {}},
    Do[
      Module[{res, gA, gSA},
        Print[\"Computing l=m=\", lv, \" ...\"];
        res = ScanAlpha[lv, lv, 0, aSpin, 40];
        gA  = res[[1]];
        gSA = res[[2]];
        If[Length[gSA] > 1,
          AppendTo[plots,
            ListLogPlot[gSA, Joined -> True,
              PlotStyle -> {cols[[lv]], Thick},
              DisplayFunction -> Identity]]
        ];
        If[Length[gA] > 1,
          AppendTo[plots,
            ListLogPlot[gA, Joined -> True,
              PlotStyle -> {Dashed, cols[[lv]]},
              DisplayFunction -> Identity]]
        ]
      ],
      {lv, 1, lMax}
    ];
    Show[plots,
      Frame -> True,
      FrameLabel -> {\"\[Alpha] = \[Mu]_a r_g\",
                     \"\[CapitalGamma] r_g (superradiance rate)\"},
      PlotLabel ->
        \"Fig. 5: Solid = semi-analytic, Dashed = analytic Eq.18\\n\" <>
        \"a/r_g = 0.999,  l=m=1,2,3,4,5  (n=0)\",
      PlotRange -> {{0, 2.5}, {10^-17, 10^-5}},
      ImageSize -> 550,
      GridLines -> Automatic,
      GridLinesStyle -> LightGray
    ]
  ]

(* ============================================================
   SECTION E: REPRODUCE FIGURE 6  (l=m=1, varying spin)
   ============================================================ *)
PlotFig6[] :=
  Module[{spins = {0.5, 0.6, 0.7, 0.8, 0.9, 0.999},
          cols, plots = {}},
    cols = Table[Hue[i/6], {i, 0, 5}];
    MapThread[
      Function[{aSpin, col},
        Module[{res, gSA},
          Print[\"Computing a/rg = \", aSpin, \" ...\"];
          res = ScanAlpha[1, 1, 0, aSpin, 40];
          gSA = res[[2]];
          If[Length[gSA] > 1,
            AppendTo[plots,
              ListLogPlot[gSA, Joined -> True,
                PlotStyle -> {col, Thick},
                DisplayFunction -> Identity]]
          ]
        ]
      ],
      {spins, cols}
    ];
    Show[plots,
      Frame -> True,
      FrameLabel -> {\"\[Alpha] = \[Mu]_a r_g\",
                     \"\[CapitalGamma] r_g\"},
      PlotLabel ->
        \"Fig. 6: l=m=1, n=0   \" <>
        \"Spins a/r_g \[Element] {0.5,0.6,0.7,0.8,0.9,0.999}\",
      PlotRange -> {{0, 0.5}, {10^-17, 10^-5}},
      ImageSize -> 550,
      GridLines -> Automatic,
      GridLinesStyle -> LightGray
    ]
  ]

(* ============================================================
   SECTION F: NUMERICAL BENCHMARKS
   ============================================================ *)
RunBenchmarks[] :=
  Module[{aS = 0.999},
    Print[\"\\n====== BENCHMARKS  (rg=1, a/rg=0.999) ======\\n\"];
    Print[\"--- Eq. 18 analytic formula ---\"];
    Do[
      Do[
        Print[StringForm[
          \"  l=m=`1`, n=0, \[Alpha]=`2`:  \[CapitalGamma]_analytic = `3`\",
          lv, alphav,
          N[GammaAnalytic[alphav, lv, lv, 0, aS], 5]]],
        {alphav, {0.1, 0.2, 0.42}}
      ],
      {lv, 1, 3}
    ];

    Print[\"\\n--- Semi-analytic Wronskian matching ---\"];
    Do[
      Do[
        Print[StringForm[
          \"  l=m=`1`, n=0, \[Alpha]=`2`:  \[CapitalGamma]_SA = `3`\",
          lv, alphav,
          N[GammaSemiAnalytic[alphav, lv, lv, 0, aS], 5]]],
        {alphav, {0.1, 0.2, 0.42}}
      ],
      {lv, 1, 3}
    ];

    Print[\"\\n--- Key paper benchmark (Fig. 5): l=m=1, n=0, \[Alpha]=0.42 \
---\"];
    Print[\"  Expected: \[CapitalGamma]_max ~ 1.5 x 10^-7  r_g^-1\"];
    Print[\"  Analytic:       \", N[GammaAnalytic[0.42, 1, 1, 0, aS], 6]];
    Print[\"  Semi-analytic:  \", N[GammaSemiAnalytic[0.42, 1, 1, 0, aS,
                                    Verbose -> True], 6]];
    Print[\"\\n============================================\\n\"]
  ]

(* ---- Run benchmarks immediately ---- *)
RunBenchmarks[]

Print[\"To reproduce Fig. 5: PlotFig5[]\"];
Print[\"To reproduce Fig. 6: PlotFig6[]\"];
Print[\"Single call example:\"];
Print[\"  GammaSemiAnalytic[0.42, 1, 1, 0, 0.999, Verbose->True]\"];
Print[\"  GammaAnalytic[0.42, 1, 1, 0, 0.999]\"];
\
