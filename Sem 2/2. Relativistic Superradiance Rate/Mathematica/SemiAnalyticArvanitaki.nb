Cell[BoxData[
 InterpretationBox["\<\"  l=m=\\!\\(\\*RowBox[{\\\"1\\\"}]\\), n=0, \[Alpha]=\
\\!\\(\\*RowBox[{\\\"0.42`\\\"}]\\):  \[CapitalGamma]_SA = \
